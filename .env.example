NODE_ENV=development
PORT=3000

FEISHU_APP_ID=cli_xxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_APP_TOKEN_KEY=feishu:token:tenant
FEISHU_DOMAIN=https://open.feishu.cn

# 数据库配置 - 默认使用 MySQL socket 连接
DB_DIALECT=mysql

# MySQL Socket 连接配置（推荐使用）
DB_SOCKET_PATH=/var/run/mysqld/mysqld.sock

# MySQL TCP 配置（如果 socket 连接不可用）
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=feishu_docs
DB_USERNAME=root
DB_PASSWORD=your_password
DB_CHARSET=utf8mb4

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=feishu:docs:

JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

LOG_LEVEL=info
LOG_FILE=./logs/app.log
